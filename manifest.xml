<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>ChemRef</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="ChemRef"/>
  <Description DefaultValue="Track compound numbering, names, and structures across your chemistry manuscript."/>
  <!-- TaskPaneApp element order: IconUrl / HighResolutionIconUrl / SupportUrl before Hosts (see manifest-element-ordering). -->
  <IconUrl DefaultValue="https://jinltan9-maker.github.io/chemref/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://jinltan9-maker.github.io/chemref/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://jinltan9-maker.github.io/chemref/support.html"/>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://jinltan9-maker.github.io/chemref/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Ribbon: custom "ChemRef" tab + task pane. DesktopFormFactor applies to Word on Windows, Mac, and the web. -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="ChemRef.Tab">
              <Group id="ChemRef.Group.Main">
                <Label resid="GroupMain.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="ChemRef.Button.ShowTaskpane">
                  <Label resid="ShowTaskpane.Label"/>
                  <Supertip>
                    <Title resid="ShowTaskpane.Label"/>
                    <Description resid="ShowTaskpane.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ChemRef.Taskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
              <Label resid="CustomTab.Label"/>
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://jinltan9-maker.github.io/chemref/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://jinltan9-maker.github.io/chemref/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://jinltan9-maker.github.io/chemref/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://jinltan9-maker.github.io/chemref/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://jinltan9-maker.github.io/chemref/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="CustomTab.Label" DefaultValue="ChemRef"/>
        <bt:String id="GroupMain.Label" DefaultValue="ChemRef"/>
        <bt:String id="ShowTaskpane.Label" DefaultValue="Show ChemRef"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ShowTaskpane.Tooltip" DefaultValue="Open the ChemRef compound tracker task pane."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
